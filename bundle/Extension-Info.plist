<?xml version="1.0" encoding="UTF-8"?>
<!--
  Info.plist for the FSKit extension (.appex).  TEMPLATE — reconcile against the
  "File System Extension" target Xcode generates on this macOS, which is the
  authoritative source for the NSExtensionPointIdentifier and the FSKit module
  keys.  The extension-point id is believed to be `com.apple.fskit.fsmodule`;
  confirm it before relying on it.  `NSExtensionPrincipalClass` must match the
  ObjC runtime name of the class defined in ext/src/lib.rs (`S3FileSystem`).
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>com.lucsoft.fskit-s3.ext</string>
    <key>CFBundleName</key>
    <string>fskit-s3</string>
    <key>CFBundlePackageType</key>
    <string>XPC!</string>
    <key>CFBundleExecutable</key>
    <string>fskit_s3_ext</string>
    <key>NSExtension</key>
    <dict>
        <key>NSExtensionPointIdentifier</key>
        <string>com.apple.fskit.fsmodule</string>
        <key>NSExtensionPrincipalClass</key>
        <string>S3FileSystem</string>
    </dict>
    <!-- FSKit module descriptor. FSShortName is a confirmed key (FSKit headers). -->
    <key>FSShortName</key>
    <string>fskit-s3</string>
    <key>FSSupportsBlockResources</key>
    <false/>
</dict>
</plist>
