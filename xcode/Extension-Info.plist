<?xml version="1.0" encoding="UTF-8"?>
<!-- Info.plist for the ExtensionKit FSKit extension.
     The EXAppExtensionAttributes block mirrors Apple's FSKitSample and fuse-t: a
     complete FS module declares its option syntaxes, (empty) media types and
     personalities, and its supported resource kinds — not just the short name.
     We're device-less, so we accept PathURL resources, not a block device. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>EXAppExtensionAttributes</key>
    <dict>
        <key>EXExtensionPointIdentifier</key>
        <string>com.apple.fskit.fsmodule</string>
        <key>FSShortName</key>
        <string>fskit-s3</string>
        <key>FSSupportsBlockResources</key>
        <false/>
        <key>FSSupportsPathURLs</key>
        <true/>
        <key>FSSupportsServerURLs</key>
        <false/>
        <key>FSSupportsGenericURLResources</key>
        <false/>
        <key>FSRequiresSecurityScopedPathURLResources</key>
        <false/>
        <key>FSActivateOptionSyntax</key>
        <dict>
            <key>shortOptions</key>
            <string></string>
        </dict>
        <key>FSCheckOptionSyntax</key>
        <dict>
            <key>shortOptions</key>
            <string></string>
        </dict>
        <key>FSFormatOptionSyntax</key>
        <dict>
            <key>shortOptions</key>
            <string></string>
        </dict>
        <key>FSMediaTypes</key>
        <dict/>
        <key>FSPersonalities</key>
        <dict/>
    </dict>
</dict>
</plist>
