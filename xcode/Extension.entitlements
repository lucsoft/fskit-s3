<?xml version="1.0" encoding="UTF-8"?>
<!-- Entitlements for the FSKit extension target. The FSKit Module capability
     (com.apple.developer.fskit.fsmodule) must be authorized on the App ID in
     your Apple Developer account — add it via Xcode ▸ Signing & Capabilities. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>com.apple.developer.fskit.fsmodule</key>
    <true/>
    <key>com.apple.security.app-sandbox</key>
    <true/>
    <!-- Outbound HTTPS for the S3 backend. -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Shared Keychain access group: the extension reads the S3 secret the app
         stored here. Must match the app's group exactly (same team-id prefix). -->
    <key>keychain-access-groups</key>
    <array>
        <string>$(AppIdentifierPrefix)dev.lucsoft.fskit-s3</string>
    </array>
</dict>
</plist>
